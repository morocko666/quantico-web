---
// src/layouts/Layout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MenuOverlay from '../components/MenuOverlay.astro';

// Detectamos si la ruta actual es la página de inicio
const isHome = Astro.url.pathname === '/';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Quantico Films</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;700;800&display=swap" rel="stylesheet">

    <style is:global>
      /* --- SISTEMA TIPOGRÁFICO Y DE COLORES DE QUANTICO --- */
      :root {
        --font-primary: 'Montserrat', sans-serif;
        
        --bg-main: #0F3E4D;
        --bg-secondary: #007077;
        --bg-menu: #0A181D;
        --accent: #D5752D;
        --text: #FFFFFF;
      }

      body {
        margin: 0;
        background-color: var(--bg-main);
        color: var(--text);
        font-family: var(--font-primary);
        -webkit-font-smoothing: antialiased;
      }

      .sys-h1 { font-family: var(--font-primary); font-size: 8rem; font-weight: 700; line-height: 1; letter-spacing: -0.01em; margin: 0; }
      .sys-h2 { font-family: var(--font-primary); font-size: 2rem; font-weight: 500; line-height: normal; letter-spacing: 0; margin: 0; }
      .sys-h3 { font-family: var(--font-primary); font-size: 2.5rem; font-weight: 500; line-height: normal; letter-spacing: 0; margin: 0; }
      .sys-subtitle { font-family: var(--font-primary); font-size: 1.5rem; font-weight: 700; line-height: 1; letter-spacing: 0; margin: 0; }
      .sys-body { font-family: var(--font-primary); font-size: 1.125rem; font-weight: 400; line-height: 1.2; letter-spacing: 0; margin: 0; }
      .sys-label { font-family: var(--font-primary); font-size: 1rem; font-weight: 700; line-height: 1; letter-spacing: 0.08em; text-transform: uppercase; margin: 0; }
      .sys-card-title { font-family: var(--font-primary); font-size: 1.125rem; font-weight: 800; line-height: -0.02em; margin: 0; }
      .sys-card-subtitle { font-family: var(--font-primary); font-size: 1.125rem; font-weight: 500; line-height: 1; letter-spacing: 0; margin: 0; }
      .sys-menu-desktop { font-family: var(--font-primary); font-size: 5rem; font-weight: 700; line-height: 1; letter-spacing: -0.01em; margin: 0; }
    </style>
  </head>
  <body>
    <MenuOverlay />
    
    <Header />
    
    <main>
      <slot />
    </main>

    {!isHome && <Footer />}
  </body>
</html>