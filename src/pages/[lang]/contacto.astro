---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import MenuOverlay from '../../components/MenuOverlay.astro';
import { sanityClient } from '../../lib/sanity';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;

const query = `*[_type == "pageContacto"][0]{
  pageTitle,
  vimeoId,
  contactList[]{
    name,
    role,
    email
  },
  socials[]{
    title,
    networkName,
    link
  }
}`;

const pageData = await sanityClient.fetch(query).catch(() => null);

const getText = (field) => {
  if (!field) return '';
  if (typeof field === 'string') return field;
  if (lang === 'en' && field.en) return field.en;
  if (field.es) return field.es;
  return '';
};

const title = getText(pageData?.pageTitle) || 'Contacto';
const rawVimeoId = getText(pageData?.vimeoId);
const vimeoId = rawVimeoId ? rawVimeoId.trim() : null;
const contacts = pageData?.contactList || [];
const socials = pageData?.socials || [];
---

<Layout>
  <Header />
  <MenuOverlay />

  <main class="page-contacto">
    <div class="split-layout">
      
      <div class="left-panel">
        <iframe
          src={`https://player.vimeo.com/video/${vimeoId || '76979871'}?background=1&autoplay=1&loop=1&byline=0&title=0`}
          frameborder="0"
          allow="autoplay; fullscreen"
          allowfullscreen
          class="bg-video"
        ></iframe>
        <div class="overlay"></div>
      </div>

      <div class="right-panel">
        <div class="content-container">
          <h1 class="page-title">{title}</h1>
          
          <div class="contact-list">
            {contacts.map((contact) => (
              <div class="contact-item">
                <h2 class="contact-name">{contact.name}</h2>
                <p class="contact-role">{getText(contact.role)}</p>
                <a href={`mailto:${contact.email}`} class="contact-email">{contact.email}</a>
              </div>
            ))}
          </div>

          {socials.length > 0 && (
            <div class="socials-container">
              {socials.map((social, index) => (
                <span class="social-item">
                  {index === 0 && <span class="social-label">{getText(social.title)} </span>}
                  <a href={social.link} target="_blank" rel="noopener noreferrer" class="social-link">
                    {social.networkName}
                  </a>
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  footer, .site-footer { display: none !important; }
</style>

<style>
  .page-contacto { width: 100vw; height: 100vh; background-color: #123e48; }
  .split-layout { display: flex; width: 100%; height: 100%; }

  .left-panel { flex: 1; position: relative; overflow: hidden; background-color: #000; z-index: 1; }
  .bg-video { position: absolute; top: 50%; left: 50%; width: 150vw; height: 150vh; transform: translate(-50%, -50%); pointer-events: none; z-index: 2; }
  .overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.4); z-index: 3; }

  .right-panel { flex: 1; display: flex; align-items: center; justify-content: center; padding: 4rem; z-index: 10; }
  .content-container { width: 100%; max-width: 750px; color: white; display: flex; flex-direction: column; justify-content: center; }
  
  .page-title { font-size: 5rem; font-weight: 700; margin-bottom: 2rem; }
  .contact-list { display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-name { font-size: 1.5rem; font-weight: 400; margin: 0; }
  .contact-role { font-size: 0.95rem; margin: 0; opacity: 0.8; }
  .contact-email { font-size: 0.85rem; font-weight: 700; color: white; text-transform: uppercase; letter-spacing: 1px; }

  .socials-container { margin-top: 3rem; display: flex; gap: 1rem; font-size: 0.8rem; text-transform: uppercase; }
  .social-link { color: white; font-weight: 700; }

/* =========================================
     OPTIMIZACIÓN PARA MOBILE (FIX)
     ========================================= */
  @media (max-width: 1024px) {
    .split-layout { 
      display: block; 
      position: relative;
    }
    
    body { 
      overflow-y: auto; 
    }

    /* Video de fondo absoluto */
    .left-panel { 
      position: fixed; /* Fijo para que siempre cubra toda la pantalla */
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      z-index: 0; /* Aseguramos que esté al fondo */
    }

    .bg-video {
      width: 100%;
      height: 100%;
      object-fit: cover; /* Asegura el efecto cover real */
    }

    .overlay {
      background: rgba(0, 0, 0, 0.6); /* Velo más oscuro para legibilidad */
      z-index: 1;
    }
    
    /* Panel de texto flotando sobre el video */
    .right-panel { 
      position: relative;
      width: 100%;
      padding: 6rem 2rem 4rem 2rem; 
      z-index: 2; /* Siempre por encima del video */
      background: transparent;
    }

    .content-container {
      align-items: flex-start;
      text-align: left;
    }
    
    .page-title {
      font-size: 3.5rem;
      margin-bottom: 2rem;
    }

    /* Ocultamos mapa y redes */
    .map-container, .socials-container { 
      display: none !important; 
    }
  }
</style>