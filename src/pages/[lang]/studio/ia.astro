---
// src/pages/[lang]/studio/ia.astro
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import MenuOverlay from '../../../components/MenuOverlay.astro';
import { sanityClient } from '../../../lib/sanity';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;

// 1. Consulta GROQ (Ahora extraemos el vimeoId del proyecto referenciado)
const query = `*[_type == "pageStudioIA"][0]{
  pageTitle,
  mainTitle,
  subtitle,
  paragraph,
  videoCards[]->{ 
    title,
    subtitle,
    "directorName": director->name,
    vimeoId
  }
}`;

const pageData = await sanityClient.fetch(query).catch(() => null);

const getText = (field) => {
  if (!field) return '';
  if (typeof field === 'string') return field;
  if (lang === 'en' && field.en) return field.en;
  if (field.es) return field.es;
  return '';
};

// Textos del Menú
const tabCine = lang === 'en' ? 'FILM & TV' : 'CINE Y TV';
const tabVerticales = lang === 'en' ? 'VERTICALS' : 'VERTICALES';
const tabIA = lang === 'en' ? 'ARTIFICIAL INTELLIGENCE' : 'INTELIGENCIA ARTIFICIAL';

// Textos Principales
const title = getText(pageData?.pageTitle) || 'Studio';
const mainTitle = getText(pageData?.mainTitle) || 'Inteligencia Artificial';
const subtitle = getText(pageData?.subtitle) || 'La tecnología como aliada creativa.';
const mainParagraph = getText(pageData?.paragraph) || 'Integramos Inteligencia Artificial en nuestros procesos de desarrollo y producción para potenciar la creatividad y optimizar resultados.\n\nLa IA nos permite:\n• Acelerar procesos de conceptualización\n• Desarrollar previsualizaciones avanzadas\n• Optimizar workflows de producción\n• Expandir posibilidades visuales\n\nCreemos que la IA no reemplaza el talento humano. Lo amplifica.\n\nEn una industria que evoluciona constantemente, entendemos que dominar la tecnología es tan importante como dominar la narrativa.';

// Datos simulados actualizados con IDs reales de Vimeo para pruebas
const cards = pageData?.videoCards?.length > 0 ? pageData.videoCards : [
  { title: 'Wong', subtitle: 'Navidad osito', directorName: 'Juan Diego Servat', vimeoId: '824804225' },
  { title: 'Ford', subtitle: 'Escape', directorName: 'Rafa Carvalho', vimeoId: '76979871' },
  { title: 'Falabella', subtitle: 'Me gusta como soy', directorName: 'Pancho Tuesta', vimeoId: '304207308' }
];
---

<Layout>
  <Header />
  <MenuOverlay />

  <main class="page-studio">
    <div class="content-wrapper">
      
      <h1 class="page-title">{title}</h1>
      <div class="primary-filters">
        <a href={`/${lang}/studio/cine-y-tv`} class="filter-btn">{tabCine}</a>
        <a href={`/${lang}/studio/verticales`} class="filter-btn">{tabVerticales}</a>
        <a href={`/${lang}/studio/ia`} class="filter-btn active">{tabIA}</a>
      </div>

      <div class="intro-section">
        <h2 class="section-subtitle">{mainTitle}</h2>
        {subtitle && <p class="highlight-text">{subtitle}</p>}
        <div class="paragraphs">
          <p class="main-desc">{mainParagraph}</p>
        </div>
      </div>

      <div class="ia-slider-container">
        <div class="ia-slider-track">
          {cards.map((card) => (
            <button 
              class="ia-card" 
              data-vimeo-id={card.vimeoId}
              style={`background-image: url('https://vumbnail.com/${card.vimeoId}.jpg');`}
            >
              <div class="card-overlay">
                <div class="card-info-left">
                  <h3 class="card-title">{getText(card.title)}</h3>
                  <p class="card-subtitle">{getText(card.subtitle)}</p>
                </div>
                <div class="card-info-right">
                  <p class="card-director">{card.directorName}</p>
                </div>
              </div>
            </button>
          ))}
        </div>
      </div>

    </div>
  </main>

  <div id="ia-video-modal" class="grid-modal hidden">
    <button id="close-ia-modal" class="close-modal" aria-label="Cerrar">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="modal-video-wrapper">
      <iframe 
        id="ia-iframe" 
        src="" 
        frameborder="0" 
        allow="autoplay; fullscreen; picture-in-picture" 
        allowfullscreen>
      </iframe>
    </div>
  </div>
</Layout>

<style>
  :root {
    --bg-dark: #112d34;
    --accent: #d86a38;
    --text-light: #7da5af;
  }

  body { background-color: var(--bg-dark); }

  .page-studio {
    min-height: 100vh; width: 100%;
    padding-top: 10rem; padding-bottom: 6rem;
    color: white; overflow-x: hidden;
  }

  .content-wrapper {
    width: 100%; padding: 0 4rem; box-sizing: border-box;
  }

  .page-title {
    font-size: 5rem; font-weight: 700; margin: 0 0 2rem 0; letter-spacing: -1px;
  }

  .primary-filters { display: flex; gap: 1rem; margin-bottom: 4rem; flex-wrap: wrap; }
  .filter-btn {
    padding: 0.6rem 1.2rem; border-radius: 4px; font-weight: 700;
    font-size: 0.85rem; text-decoration: none; transition: all 0.3s ease;
  }
  .filter-btn.active { background-color: var(--accent); color: white; }
  .filter-btn:not(.active) { background-color: white; color: var(--accent); }
  .filter-btn:not(.active):hover { opacity: 0.8; }

  .intro-section { max-width: 1000px; margin-bottom: 4rem; }
  .section-subtitle { font-size: 2.5rem; font-weight: 400; margin: 0 0 1.5rem 0; }
  .highlight-text { color: var(--text-light); font-weight: 700; margin-bottom: 1.5rem; font-size: 1.1rem; }
  .main-desc { color: var(--text-light); font-size: 1rem; line-height: 1.6; white-space: pre-wrap; }

  /* --- SLIDER IA --- */
  .ia-slider-container { width: 100%; position: relative; max-width: 100vw; }
  .ia-slider-track {
    display: flex; gap: 2rem; overflow-x: auto; padding-bottom: 2rem;
    scroll-snap-type: x mandatory; scroll-behavior: smooth; scrollbar-width: none; 
  }
  .ia-slider-track::-webkit-scrollbar { display: none; }

  .ia-card {
    flex: 0 0 auto; width: 600px; aspect-ratio: 16 / 9;
    background-color: #1a3d46; background-size: cover; background-position: center;
    border-radius: 12px; overflow: hidden; scroll-snap-align: start;
    position: relative; cursor: pointer; border: none; padding: 0;
    text-align: left; transition: transform 0.4s ease;
  }
  .ia-card:hover { transform: scale(1.02); }

  .card-overlay {
    position: absolute; bottom: 0; left: 0; width: 100%;
    padding: 3rem 2rem 1.5rem 2rem;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
    display: flex; justify-content: space-between; align-items: flex-end;
    box-sizing: border-box;
  }

  .card-title { font-size: 1.8rem; font-weight: 700; margin: 0; color: white; line-height: 1.1; }
  .card-subtitle { font-size: 0.9rem; margin: 0; color: white; opacity: 0.9; }
  .card-director { font-size: 0.9rem; margin: 0; color: white; opacity: 0.9; }

  /* --- ESTILOS DEL MODAL --- */
  .grid-modal {
    position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
    background-color: rgba(0, 0, 0, 0.95); z-index: 99999;
    display: flex; align-items: center; justify-content: center;
    opacity: 1; visibility: visible; transition: opacity 0.4s ease, visibility 0.4s ease;
  }
  .grid-modal.hidden { opacity: 0; visibility: hidden; pointer-events: none; }

  .close-modal {
    position: absolute; top: 2.5rem; right: 3rem; background: none; border: none;
    color: #fff; cursor: pointer; z-index: 10; transition: all 0.3s ease;
    display: flex; align-items: center; justify-content: center;
  }
  .close-modal:hover { opacity: 0.6; transform: scale(1.1); }

  .modal-video-wrapper {
    width: 90vw; max-width: 1400px; max-height: 85vh; aspect-ratio: 16 / 9; position: relative;
  }
  .modal-video-wrapper iframe { width: 100%; height: 100%; position: absolute; top: 0; left: 0; }

  @media (max-width: 1024px) {
    .ia-card { width: 65vw; }
  }
  @media (max-width: 768px) {
    .content-wrapper { padding: 0 24px; }
    .page-title { font-size: 3.5rem; }
    .ia-card { width: 85vw; }
    .card-title { font-size: 1.5rem; }
    .close-modal { top: 1.5rem; right: 1.5rem; }
    .modal-video-wrapper { width: 100vw; max-height: none; } 
  }
</style>

<script>
  const initIAModal = () => {
    const cards = document.querySelectorAll('.ia-card');
    const modal = document.getElementById('ia-video-modal');
    const iframe = document.getElementById('ia-iframe');
    const closeBtn = document.getElementById('close-ia-modal');

    // Escuchamos clics en las tarjetas
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        e.preventDefault(); 
        const vimeoId = card.getAttribute('data-vimeo-id');
        
        if (vimeoId && modal && iframe) {
          iframe.src = `https://player.vimeo.com/video/${vimeoId}?autoplay=1&title=0&byline=0&portrait=0`;
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    // Escuchamos clic en cerrar
    if (closeBtn && modal && iframe) {
      closeBtn.addEventListener('click', () => {
        modal.classList.add('hidden');
        iframe.src = ''; 
        document.body.style.overflow = ''; 
      });
    }
  };

  initIAModal();
  document.addEventListener('astro:page-load', initIAModal);
</script>