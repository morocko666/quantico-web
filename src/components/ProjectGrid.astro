---
// src/components/ProjectGrid.astro
const { projects } = Astro.props;
---

<div class="project-grid">
  {projects.map((p, index) => (
    /* Agregamos data-vimeo-id para que el script sepa qué video abrir */
    <a href="#" class={`project-card pattern-${index % 5}`} data-vimeo-id={p.vimeoId}>
      <div class="thumbnail-wrapper">
        <img src={`https://vumbnail.com/${p.vimeoId}.jpg`} alt={p.title} class="thumbnail-img" />
        
        <div class="card-overlay">
          <div class="left-info">
            <h3 class="client-name">{p.category}</h3>
            <p class="project-title">{p.title}</p>
          </div>
          <div class="right-info">
            <p class="director-name">{p.director}</p>
          </div>
        </div>
      </div>
    </a>
  ))}
</div>

<div id="grid-video-modal" class="grid-modal hidden">
  <button id="close-grid-modal" class="close-modal" aria-label="Cerrar">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  
  <div class="modal-video-wrapper">
    <iframe 
      id="grid-iframe" 
      src="" 
      frameborder="0" 
      allow="autoplay; fullscreen; picture-in-picture" 
      allowfullscreen>
    </iframe>
  </div>
</div>

<style>
  /* --- ESTILOS DE LA GRILLA --- */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.5rem; 
  }

  .project-card {
    border-radius: 12px; overflow: hidden; position: relative;
    text-decoration: none; color: white; aspect-ratio: 16 / 9; 
    display: block; background-color: #111; cursor: pointer;
  }

  .pattern-0, .pattern-1 { grid-column: span 3; }
  .pattern-2, .pattern-3, .pattern-4 { grid-column: span 2; }

  .thumbnail-wrapper { width: 100%; height: 100%; position: relative; }
  .thumbnail-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .project-card:hover .thumbnail-img { transform: scale(1.05); }

  .card-overlay {
    position: absolute; bottom: 0; left: 0; width: 100%;
    padding: 2rem 1.5rem 1.5rem 1.5rem;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
    display: flex; justify-content: space-between; align-items: flex-end;
    box-sizing: border-box;
  }

  .client-name { font-size: 1.5rem; font-weight: 700; margin: 0 0 4px 0; }
  .project-title { font-size: 0.9rem; margin: 0; opacity: 0.9; }
  .director-name { font-size: 0.85rem; margin: 0; opacity: 0.9; }

  /* --- ESTILOS DEL MODAL --- */
  /* --- ESTILOS DEL MODAL --- */
  .grid-modal {
    position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
    background-color: rgba(0, 0, 0, 0.95); /* Fondo oscuro con leve transparencia */
    z-index: 99999;
    display: flex; align-items: center; justify-content: center;
    opacity: 1; visibility: visible;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .grid-modal.hidden {
    opacity: 0; visibility: hidden; pointer-events: none;
  }

  .close-modal {
    position: absolute; top: 2.5rem; right: 3rem;
    background: none; border: none; color: #fff;
    cursor: pointer; z-index: 10; transition: all 0.3s ease;
    display: flex; align-items: center; justify-content: center;
  }

  .close-modal:hover { 
    opacity: 0.6; 
    transform: scale(1.1); 
  }

  .modal-video-wrapper {
    width: 90vw; 
    max-width: 1400px;
    /* Esto obliga al video a no chocar nunca con los bordes superior/inferior */
    max-height: 85vh; 
    aspect-ratio: 16 / 9;
    position: relative;
  }

  .modal-video-wrapper iframe {
    width: 100%; height: 100%; position: absolute; top: 0; left: 0;
  }

  /* --- MOBILE --- */
  @media (max-width: 768px) {
    .project-grid { grid-template-columns: 1fr; gap: 1.2rem; }
    .pattern-0, .pattern-1, .pattern-2, .pattern-3, .pattern-4 { grid-column: span 1; }
    .client-name { font-size: 1.2rem; }
    
    .close-modal { top: 1.5rem; right: 1.5rem; }
    .close-modal svg { width: 24px; height: 24px; }
    /* En celulares sí permitimos que tome el 100% del ancho para aprovechar la pantalla */
    .modal-video-wrapper { width: 100vw; max-height: none; } 
  }

  /* --- MOBILE --- */
  @media (max-width: 768px) {
    .project-grid { grid-template-columns: 1fr; gap: 1.2rem; }
    .pattern-0, .pattern-1, .pattern-2, .pattern-3, .pattern-4 { grid-column: span 1; }
    .client-name { font-size: 1.2rem; }
    
    .close-modal { top: 1.5rem; right: 1.5rem; }
    .modal-video-wrapper { max-width: 100vw; }
  }
</style>

<script>
  const initGridModal = () => {
    const cards = document.querySelectorAll('.project-card');
    const modal = document.getElementById('grid-video-modal');
    const iframe = document.getElementById('grid-iframe');
    const closeBtn = document.getElementById('close-grid-modal');

    // Escuchamos clics en las tarjetas
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        e.preventDefault(); // Evita que la página salte hacia arriba
        const vimeoId = card.getAttribute('data-vimeo-id');
        
        if (vimeoId && modal && iframe) {
          // Armamos la URL de Vimeo (autoplay activado y controles limpios)
          iframe.src = `https://player.vimeo.com/video/${vimeoId}?autoplay=1&title=0&byline=0&portrait=0`;
          modal.classList.remove('hidden');
          // Bloqueamos el scroll del fondo
          document.body.style.overflow = 'hidden';
        }
      });
    });

    // Escuchamos clic en cerrar
    if (closeBtn && modal && iframe) {
      closeBtn.addEventListener('click', () => {
        modal.classList.add('hidden');
        iframe.src = ''; // Cortamos el iframe para detener el audio
        document.body.style.overflow = ''; // Restauramos el scroll
      });
    }
  };

  // Ejecutamos al inicio y en cada cambio de vista (ViewTransitions)
  initGridModal();
  document.addEventListener('astro:page-load', initGridModal);
</script>